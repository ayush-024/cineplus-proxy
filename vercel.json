{
  "version": 2,
  "functions": {
    "api/proxy.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "api/prxy-2.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "api/prxy-3.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    {
      "src": "/api/proxy.php",
      "dest": "/api/proxy.php"
    },
    {
      "src": "/api/prxy-2.php",
      "dest": "/api/prxy-2.php"
    },
    {
      "src": "/api/prxy-3.php",
      "dest": "/api/prxy-3.php"
    },
    {
      "src": "/",
      "dest": "/index.html",
      "headers": {
        "Content-Type": "text/html"
      }
    }
  ]
}
